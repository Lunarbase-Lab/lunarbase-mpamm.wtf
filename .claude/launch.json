{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 5173
    },
    {
      "name": "dev-sim",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 5173,
      "env": {
        "DATA_SOURCE": "sim"
      }
    },
    {
      "name": "web-prod-proxy",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "-w",
        "web",
        "run",
        "dev"
      ],
      "port": 5173,
      "env": {
        "BACKEND_URL": "https://mpamm.wtf"
      }
    }
  ]
}