# Copy to .env — every variable is optional (defaults in server/src/config.ts).

# A trusted Monad RPC. The public default works, but is rate-limited and caps
# getLogs ranges (slow venue-lifetime backfills).
#RPC_HTTP_URL=
#RPC_WS_URL=

# Offline development against the deterministic simulator (no network).
#DATA_SOURCE=sim

# Adapter development: run ONLY your venue, skip the heavy history jobs.
#VENUES=myvenue
#BACKFILL=off
#MARKOUT_BACKFILL=off
#GAS_METRIC=off
#DB_PATH=./data/scratch.db
