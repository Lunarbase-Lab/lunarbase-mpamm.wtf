# ── Data source ────────────────────────────────────────────────────────────
# sim  = fully self-contained simulator (no external deps) — default
# live = real Monad RPC (Multicall3 quotes + getLogs fills) + Bybit feed
# auto = try live; fall back to sim if the chain/Bybit are unreachable
DATA_SOURCE=auto

# ── Monad mainnet (chain id 143) ───────────────────────────────────────────
# A trusted node is recommended (spec §8). The public endpoint works for
# eth_call (quotes) and short getLogs ranges (live fill tailing) but cannot
# backfill deep history — that is seeded by the simulator/subgraph instead.
RPC_HTTP_URL=https://rpc.monad.xyz
RPC_WS_URL=wss://rpc.monad.xyz

# ── Bybit V5 (CEX benchmark) ───────────────────────────────────────────────
BYBIT_REST_URL=https://api.bybit.com
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/spot
BYBIT_SYMBOL=MONUSDT

# ── History (persist-forward indexer, live mode) ───────────────────────────
# The SQLite DB is the source of truth for daily-volume history: loaded on boot,
# advanced forward from on-chain fills, resumed from lastProcessedBlock on
# restart. Closed Clober days are seeded once from the Goldsky subgraph; LFJ
# history accumulates forward (set LFJ_API_KEY to seed LFJ from its analytics).
DB_PATH=data/mpamm.db
SUBGRAPH_URL=https://api.goldsky.com/api/public/project_clsljw95chutg01w45cio46j0/subgraphs/v2-subgraph-monad/latest/gn
SEED_SINCE_UTC=2026-05-13
# LFJ_API_KEY=

# ── Exec config ────────────────────────────────────────────────────────────
# Taker fee applied to the Bybit leg, in bps (spec D7). Default non-VIP 10 bps.
TAKER_BPS=10
# Quote poll cadence (ms). Monad blocks are ~0.4s; 500ms keeps it tip-fresh.
QUOTE_INTERVAL_MS=500

# ── Service ────────────────────────────────────────────────────────────────
# Backend API/WS port. Named API_PORT (not PORT) so it never collides with a
# frontend dev server / preview manager that injects PORT.
API_PORT=8787
